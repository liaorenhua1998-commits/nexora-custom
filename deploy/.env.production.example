# =============================================================================
# Nexora Production Runtime Environment Template
# =============================================================================
# This file is generated into ./runtime/.env.production by docker-deploy-prod.sh.
# Keep only non-secret values here. Secret values live under ./runtime/secrets/.
#
# First boot:
#   ./docker-deploy-prod.sh
#   docker compose --env-file ./runtime/.env.production -f docker-compose.prod.yml up -d --build
#
# After you log in, change the admin password in the UI and then run:
#   ./finalize-production-bootstrap.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Public entrypoint
# -----------------------------------------------------------------------------
BIND_HOST=127.0.0.1
SERVER_PORT=8080
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Hong_Kong
SERVER_TRUSTED_PROXIES=127.0.0.1/32,::1/128
AUTO_SETUP=true

# Public URLs shown to users and used in exported config / reverse proxy docs
PUBLIC_DOMAIN=api.example.com
BOOTSTRAP_FRONTEND_URL=https://api.example.com
BOOTSTRAP_API_BASE_URL=https://api.example.com
BOOTSTRAP_CONTACT_INFO=support@example.com
BOOTSTRAP_DOC_URL=https://docs.example.com

# -----------------------------------------------------------------------------
# Database / Redis
# -----------------------------------------------------------------------------
POSTGRES_USER=nexora
POSTGRES_DB=nexora
DATABASE_MAX_OPEN_CONNS=80
DATABASE_MAX_IDLE_CONNS=20
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5
REDIS_DB=0
REDIS_POOL_SIZE=512
REDIS_MIN_IDLE_CONNS=32
REDIS_ENABLE_TLS=false

# Runtime secret file paths mounted as Docker secrets
POSTGRES_PASSWORD_FILE_PATH=./runtime/secrets/postgres_password
REDIS_PASSWORD_FILE_PATH=./runtime/secrets/redis_password
ADMIN_PASSWORD_FILE_PATH=./runtime/secrets/admin_password
JWT_SECRET_FILE_PATH=./runtime/secrets/jwt_secret
TOTP_ENCRYPTION_KEY_FILE_PATH=./runtime/secrets/totp_encryption_key
BOOTSTRAP_TURNSTILE_SECRET_KEY_FILE_PATH=./runtime/secrets/turnstile_secret_key
BOOTSTRAP_SMTP_PASSWORD_FILE_PATH=./runtime/secrets/smtp_password

# -----------------------------------------------------------------------------
# Bootstrap admin and auth
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
JWT_EXPIRE_HOUR=24
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=0

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE_NAME=nexora-gateway
LOG_ENV=production
LOG_CALLER=true
LOG_STACKTRACE_LEVEL=error
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=true
LOG_OUTPUT_FILE_PATH=
LOG_ROTATION_MAX_SIZE_MB=100
LOG_ROTATION_MAX_BACKUPS=10
LOG_ROTATION_MAX_AGE_DAYS=7
LOG_ROTATION_COMPRESS=true
LOG_ROTATION_LOCAL_TIME=true

# -----------------------------------------------------------------------------
# Request sizing
# -----------------------------------------------------------------------------
SERVER_MAX_REQUEST_BODY_SIZE=268435456
GATEWAY_MAX_BODY_SIZE=268435456

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Production should keep this enabled and explicitly list every upstream host.
SECURITY_URL_ALLOWLIST_ENABLED=true
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=api.openai.com,api.anthropic.com,generativelanguage.googleapis.com,openrouter.ai
SECURITY_URL_ALLOWLIST_PRICING_HOSTS=raw.githubusercontent.com
SECURITY_URL_ALLOWLIST_CRS_HOSTS=

# -----------------------------------------------------------------------------
# Production bootstrap for DB-backed public settings
# -----------------------------------------------------------------------------
# valid values: closed | invite_only | open
BOOTSTRAP_SETTINGS_ENABLED=true
BOOTSTRAP_SETTINGS_ENFORCE=true
BOOTSTRAP_REGISTRATION_MODE=invite_only
BOOTSTRAP_EMAIL_VERIFY_ENABLED=false
BOOTSTRAP_PASSWORD_RESET_ENABLED=false
BOOTSTRAP_PROMO_CODE_ENABLED=false
BOOTSTRAP_INVITATION_CODE_ENABLED=true
BOOTSTRAP_RISK_CONTROL_ENABLED=true
BOOTSTRAP_TOTP_ENABLED=true

# Optional Turnstile. Leave disabled until you actually have a site key + secret.
BOOTSTRAP_TURNSTILE_ENABLED=false
BOOTSTRAP_TURNSTILE_SITE_KEY=

# Optional SMTP for system email / alert delivery.
BOOTSTRAP_SMTP_HOST=
BOOTSTRAP_SMTP_PORT=587
BOOTSTRAP_SMTP_USERNAME=
BOOTSTRAP_SMTP_FROM_EMAIL=
BOOTSTRAP_SMTP_FROM_NAME=Nexora Alerts
BOOTSTRAP_SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# Ops alert bootstrap
# -----------------------------------------------------------------------------
BOOTSTRAP_OPS_SETTINGS_ENABLED=true
BOOTSTRAP_OPS_ALERT_EMAIL_ENABLED=false
BOOTSTRAP_OPS_ALERT_EMAIL_RECIPIENTS=ops@example.com
BOOTSTRAP_OPS_ALERT_EMAIL_RATE_LIMIT_PER_HOUR=12
BOOTSTRAP_OPS_ALERT_EMAIL_BATCHING_WINDOW_SECONDS=60
BOOTSTRAP_OPS_ALERT_INCLUDE_RESOLVED=false
BOOTSTRAP_OPS_ALERT_RULES_ENABLED=true
BOOTSTRAP_OPS_ALERT_RULES_ENFORCE=true
BOOTSTRAP_OPS_ERROR_RATE_THRESHOLD=5
BOOTSTRAP_OPS_UPSTREAM_ERROR_RATE_THRESHOLD=5
BOOTSTRAP_OPS_SUCCESS_RATE_THRESHOLD=99
BOOTSTRAP_OPS_SLA_PERCENT_MIN=99.5
BOOTSTRAP_OPS_TTFT_P99_MS_MAX=500

# -----------------------------------------------------------------------------
# Optional outbound proxy for update/pricing jobs
# -----------------------------------------------------------------------------
# GitHub release repository used by the in-app updater.
# Use your branded fork here, for example: your-name/your-branded-sub2api
UPDATE_GITHUB_REPO=Wei-Shaw/sub2api
UPDATE_PROXY_URL=

# -----------------------------------------------------------------------------
# Optional OAuth / quota settings
# -----------------------------------------------------------------------------
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=
GEMINI_QUOTA_POLICY=
GEMINI_CLI_OAUTH_CLIENT_ID=
GEMINI_CLI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_ID=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Optional image gateway tuning
# -----------------------------------------------------------------------------
GATEWAY_IMAGE_STREAM_DATA_INTERVAL_TIMEOUT=900
GATEWAY_IMAGE_STREAM_KEEPALIVE_INTERVAL=10
GATEWAY_IMAGE_CONCURRENCY_ENABLED=false
GATEWAY_IMAGE_CONCURRENCY_MAX_CONCURRENT_REQUESTS=0
GATEWAY_IMAGE_CONCURRENCY_OVERFLOW_MODE=reject
GATEWAY_IMAGE_CONCURRENCY_WAIT_TIMEOUT_SECONDS=30
GATEWAY_IMAGE_CONCURRENCY_MAX_WAITING_REQUESTS=100

# -----------------------------------------------------------------------------
# Host-side monitor script
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
MONITOR_ALERT_WEBHOOK_URL=
